// -------------------------------------------------------------------------

#include "config.h"

// Provisioning details
const char* DEVICE_ID = "bin-0142";
const char* ZONE_ID = "district-7";

// Network credentials
const char* WIFI_SSID = "YOUR_WIFI_SSID_HERE";
const char* WIFI_PASSWORD = "YOUR_WIFI_PASSWORD_HERE";

// MQTT credentials
const char* MQTT_SERVER = "YOUR_MQTT_BROKER_IP_HERE";
const int MQTT_PORT = 8883;                         // Secure MQTTS Port
const char* MQTT_USER = "bin_device";
const char* MQTT_PASSWORD = "YOUR_SECURE_PASSWORD_HERE";

// Root CA Certificate for Broker validation (Use C++11 Raw String Literal)
const char* MQTT_CA_CERT = R"EOF(
-----BEGIN CERTIFICATE-----
YOUR_GENERATED_CA_CRT_CONTENT_HERE
-----END CERTIFICATE-----
)EOF";

// Initialize mutable remote configuration (Default: 5 seconds)
volatile unsigned long measureIntervalMs = 5000;
