# Database Credentials
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD

# MQTT Broker Credentials
MQTT_BIN_PASSWORD=YOUR_MQTT_DEVICE_PASSWORD
MQTT_INGESTION_PASSWORD=YOUR_MQTT_BACKEND_PASSWORD

# JWT Security Configurations (Generate a secure 32-byte hex key)
JWT_SECRET=YOUR_SECURE_JWT_SECRET_KEY

# Initial Administrator Credentials (Will be hashed on startup)
INITIAL_ADMIN_PASSWORD=YOUR_INITIAL_ADMIN_PASSWORD
